{
  "schemaVersion": 1,
  "key": "minimax",
  "label": "MiniMax Cloud",
  "description": "MiniMax-M3 via MiniMax Cloud",
  "displayOrder": 20,
  "baseUrl": "https://api.minimax.io/anthropic",
  "auth": {
    "mode": "apiKey",
    "apiKeyLabel": "MiniMax API key",
    "credentialEnv": "MINIMAX_API_KEY"
  },
  "models": {
    "default": "MiniMax-M3",
    "smallFast": "MiniMax-M3",
    "opus": "MiniMax-M3",
    "sonnet": "MiniMax-M3",
    "haiku": "MiniMax-M3",
    "subagent": "",
    "requiresModelMapping": false
  },
  "env": {
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "512000"
  },
  "variant": {
    "splashStyle": "minimax",
    "noPromptPack": false,
    "theme": {
      "id": "dark",
      "name": "MiniMax Cloud",
      "palette": {
        "base": "#0a0a12",
        "surface": "#12121e",
        "panel": "#18182a",
        "border": "#2a2a44",
        "borderStrong": "#3d3d5c",
        "text": "#eeeef8",
        "textMuted": "#c4c4da",
        "textDim": "#8888aa",
        "accent": "#a855f7",
        "accentDeep": "#7c3aed",
        "blue": "#6366f1",
        "green": "#34d399",
        "red": "#f43f5e",
        "orange": "#f59e0b",
        "purple": "#7c3aed"
      }
    },
    "promptOverlays": {
      "webfetch": "When provider-specific docs, search, web reading, or image tools are relevant, prefer configured MiniMax resources such as the MiniMax docs and MiniMax MCP server available in this isolated setup.",
      "explore": "This Claude Code setup is configured for MiniMax Cloud using MiniMax-M3 through the MiniMax Anthropic-compatible endpoint. Keep model and provider assumptions consistent with that endpoint.",
      "planEnhanced": "Plan with the active MiniMax Cloud provider and MiniMax-M3 model mapping in mind. Do not assume first-party Claude model names or Anthropic-only behavior unless this setup explicitly configures them."
    }
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [
      "WebSearch"
    ],
    "mcpServers": {
      "MiniMax": {
        "type": "stdio",
        "command": "uvx",
        "args": [
          "minimax-coding-plan-mcp",
          "-y"
        ],
        "env": {
          "MINIMAX_API_KEY": "${MINIMAX_API_KEY}",
          "MINIMAX_API_HOST": "https://api.minimax.io"
        }
      }
    }
  },
  "tui": {
    "headline": "MiniMax M3",
    "features": [
      "MiniMax-M3 defaults across all tiers",
      "Anthropic-compatible endpoint",
      "MiniMax MCP server registered for web and image tools"
    ],
    "setupLinks": {
      "subscribe": "https://platform.minimax.io/subscribe/coding-plan",
      "apiKey": "https://platform.minimax.io/user-center/payment/coding-plan",
      "docs": "https://platform.minimax.io/docs"
    },
    "setupNote": "Subscribe to the MiniMax Coding Plan and provide MINIMAX_API_KEY."
  }
}
