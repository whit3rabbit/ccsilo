{
  "schemaVersion": 1,
  "key": "ccrouter",
  "label": "CC Router",
  "description": "Local Claude Code Router service at 127.0.0.1:3456",
  "displayOrder": 110,
  "baseUrl": "http://127.0.0.1:3456",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "Router token",
    "credentialEnv": "CCROUTER_AUTH_TOKEN",
    "credentialOptional": true,
    "authTokenFallback": "ccrouter-proxy"
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": false
  },
  "env": {
    "API_TIMEOUT_MS": "3000000",
    "NO_PROXY": "127.0.0.1",
    "DISABLE_TELEMETRY": "true",
    "DISABLE_COST_WARNINGS": "true"
  },
  "envUnset": [
    "CLAUDE_CODE_USE_BEDROCK"
  ],
  "variant": {
    "splashStyle": "ccrouter",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "CC Router",
      "palette": {
        "base": "#0c1320",
        "surface": "#111a2a",
        "panel": "#16233a",
        "border": "#2a3f61",
        "borderStrong": "#3f5f90",
        "text": "#e7f1ff",
        "textMuted": "#bfd0e8",
        "textDim": "#8ca4c4",
        "accent": "#4da3ff",
        "accentSoft": "#7bbcff",
        "accentDeep": "#2a6fcb",
        "blue": "#64d5ff",
        "green": "#2fb37f",
        "red": "#e06b7a",
        "orange": "#d9a04d",
        "purple": "#7e8fe0"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "CC Router",
    "section": "pinned",
    "features": [
      "Generic local gateway at 127.0.0.1:3456",
      "Models are configured in Claude Code Router",
      "Managed mode keeps CCR npm install and HOME under this setup",
      "Optional router token must match CCR APIKEY when configured"
    ],
    "setupLinks": {
      "subscribe": "https://github.com/musistudio/claude-code-router#installation",
      "apiKey": "https://github.com/musistudio/claude-code-router#2-configuration",
      "docs": "https://musistudio.github.io/claude-code-router/docs/cli/config/basic/",
      "ccsilo": "docs/CCR.md"
    },
    "setupNote": "Managed mode installs CCR locally, sets HOME to the setup-local CCR home, copies or seeds config, and auto-starts the router. Edit the setup-local config shown after create. Use external mode only when you want to run a global CCR service yourself."
  }
}
