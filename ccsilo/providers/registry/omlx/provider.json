{
  "schemaVersion": 1,
  "key": "omlx",
  "label": "oMLX",
  "description": "Local MLX-powered models through oMLX",
  "displayOrder": 203,
  "baseUrl": "http://localhost:8000",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "oMLX API key",
    "credentialEnv": "OMLX_API_KEY",
    "credentialOptional": true,
    "authTokenFallback": "omlx",
    "authTokenAlsoSetsApiKey": true
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": true
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "defaultVariantName": "ccomlx",
    "splashStyle": "omlx",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "oMLX",
      "palette": {
        "base": "#13151a",
        "surface": "#1a1d24",
        "panel": "#22252e",
        "border": "#3a3e4a",
        "borderStrong": "#4a4f5c",
        "text": "#e8eaed",
        "textMuted": "#b0b5bc",
        "textDim": "#7a8088",
        "accent": "#7aa2f7",
        "accentSoft": "#a4b8f8",
        "accentDeep": "#5b7de0",
        "blue": "#bb9af7",
        "green": "#37d995",
        "red": "#fb2c36",
        "orange": "#ff8e42",
        "purple": "#bb9af7"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "oMLX",
    "section": "local",
    "modelDiscovery": {
      "enabled": true
    },
    "features": [
      "Local oMLX server",
      "MLX-optimized macOS models",
      "Optional API key for custom local auth"
    ],
    "setupLinks": {
      "docs": "https://omlx.ai/",
      "apiKey": "https://omlx.ai/",
      "subscribe": "https://omlx.ai/"
    },
    "setupNote": "Run oMLX locally, then keep the default endpoint or edit the port."
  }
}
