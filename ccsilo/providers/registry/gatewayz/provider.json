{
  "schemaVersion": 1,
  "key": "gatewayz",
  "label": "GatewayZ",
  "description": "GatewayZ AI Gateway",
  "displayOrder": 140,
  "baseUrl": "https://api.gatewayz.ai",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "GatewayZ API key",
    "credentialEnv": "GATEWAYZ_API_KEY"
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": true
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "splashStyle": "gatewayz",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "GatewayZ",
      "palette": {
        "base": "#120d1d",
        "surface": "#1a1328",
        "panel": "#211736",
        "border": "#35285a",
        "borderStrong": "#4d3a80",
        "text": "#efe8ff",
        "textMuted": "#cfc0f2",
        "textDim": "#9f8ec7",
        "accent": "#9a6dff",
        "accentSoft": "#b38dff",
        "accentDeep": "#6a3fd6",
        "blue": "#6f8dff",
        "green": "#2fb37f",
        "red": "#e06b7a",
        "orange": "#d9a04d",
        "purple": "#9a6dff"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "GatewayZ",
    "features": [
      "Single gateway for multiple providers",
      "Requires Opus, Sonnet, and Haiku model aliases",
      "Auth token mode"
    ],
    "setupLinks": {
      "subscribe": "https://gatewayz.ai",
      "apiKey": "https://gatewayz.ai",
      "docs": "https://docs.gatewayz.ai/docs/anthropic-compatibility"
    },
    "setupNote": "Provide a GatewayZ API key and configure model aliases."
  }
}
