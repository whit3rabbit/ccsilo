{
  "schemaVersion": 1,
  "key": "openrouter",
  "label": "OpenRouter",
  "description": "100+ models via OpenRouter gateway",
  "displayOrder": 70,
  "baseUrl": "https://openrouter.ai/api",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "OpenRouter API key",
    "credentialEnv": "OPENROUTER_API_KEY"
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": true
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "splashStyle": "openrouter",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "OpenRouter",
      "palette": {
        "base": "#0d0f12",
        "surface": "#14161a",
        "panel": "#1a1d22",
        "border": "#3a3f48",
        "borderStrong": "#4a5058",
        "text": "#e8eaed",
        "textMuted": "#b0b5bc",
        "textDim": "#7a8088",
        "accent": "#c0c0c0",
        "accentSoft": "#e5e4e2",
        "accentDeep": "#a0a0a0",
        "blue": "#00d4ff",
        "green": "#4ade80",
        "red": "#f87171",
        "orange": "#fb923c",
        "purple": "#6b5b95"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "OpenRouter",
    "modelDiscovery": {
      "enabled": true
    },
    "features": [
      "Gateway for many model providers",
      "Requires Opus, Sonnet, and Haiku model aliases",
      "Auth token mode"
    ],
    "setupLinks": {
      "subscribe": "https://openrouter.ai/account",
      "apiKey": "https://openrouter.ai/keys",
      "docs": "https://openrouter.ai/docs"
    },
    "setupNote": "Create an API key and map each Claude Code tier to an OpenRouter model id."
  }
}
