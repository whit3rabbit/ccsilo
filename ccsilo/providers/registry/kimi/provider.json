{
  "schemaVersion": 1,
  "key": "kimi",
  "label": "Kimi Code",
  "description": "kimi-for-coding via Kimi Code (K2.5)",
  "displayOrder": 10,
  "baseUrl": "https://api.kimi.com/coding/",
  "auth": {
    "mode": "apiKey",
    "apiKeyLabel": "Kimi API key",
    "credentialEnv": "KIMI_API_KEY"
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "kimi-for-coding",
    "sonnet": "kimi-for-coding",
    "haiku": "kimi-for-coding",
    "subagent": "",
    "requiresModelMapping": false
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
