  "tui": {
    "headline": "Kimi Code",
    "features": [
      "Anthropic-compatible Kimi Code endpoint",
      "kimi-for-coding defaults across all tiers",
      "Long-context coding sessions"
    ],
    "setupLinks": {
      "subscribe": "https://www.kimi.com/code",
      "apiKey": "https://www.kimi.com/code/console",
      "docs": "https://www.kimi.com/code/docs/en/more/third-party-agents.html"
    },
    "setupNote": "Subscribe to Kimi Code and create an API key in the console."
  }
