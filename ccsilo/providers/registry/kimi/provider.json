        "surface": "#111d2b",
        "panel": "#142231",
        "border": "#1e3448",
        "borderStrong": "#2a4a64",
        "text": "#e8f0f8",
        "textMuted": "#b8cad8",
        "textDim": "#6b8aa0",
        "accent": "#22d3ee",
        "accentSoft": "#67e8f9",
        "accentDeep": "#0891b2",
        "blue": "#06b6d4",
        "green": "#34d399",
        "red": "#fb7185",
        "orange": "#f59e0b",
        "purple": "#8b5cf6"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "Kimi Code",
    "features": [
