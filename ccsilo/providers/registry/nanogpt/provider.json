{
  "schemaVersion": 1,
  "key": "nanogpt",
  "label": "NanoGPT",
  "description": "400+ models via NanoGPT gateway",
  "displayOrder": 100,
  "baseUrl": "https://nano-gpt.com/api",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "NanoGPT API key",
    "credentialEnv": "NANOGPT_API_KEY"
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "moonshotai/kimi-k2.5",
    "sonnet": "moonshotai/kimi-k2.5",
    "haiku": "moonshotai/kimi-k2.5",
    "subagent": "",
    "requiresModelMapping": true
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "splashStyle": "nanogpt",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "NanoGPT",
      "palette": {
        "base": "#070b0a",
        "surface": "#0c1411",
        "panel": "#0f1d18",
        "border": "#1c2d25",
        "borderStrong": "#2a4034",
        "text": "#eafff3",
        "textMuted": "#c8e8d6",
        "textDim": "#8db7a2",
        "accent": "#00e676",
        "accentSoft": "#74ffb8",
        "blue": "#00d1ff",
        "green": "#22c55e",
        "red": "#ff3b3b",
        "orange": "#ff8c42",
        "purple": "#7c3aed"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "NanoGPT",
    "features": [
      "Gateway to hundreds of models",
      "Kimi K2.5 defaults",
      "Model aliases remain editable"
    ],
    "setupLinks": {
      "subscribe": "https://nano-gpt.com",
      "apiKey": "https://nano-gpt.com/api",
      "docs": "https://docs.nano-gpt.com/integrations/claude-code"
    },
    "setupNote": "Create an API key and override model aliases if desired."
  }
}
