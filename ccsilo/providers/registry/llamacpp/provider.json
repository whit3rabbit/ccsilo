{
  "schemaVersion": 1,
  "key": "llamacpp",
  "label": "llama.cpp",
  "description": "Local GGUF models through a llama.cpp server",
  "displayOrder": 201,
  "baseUrl": "http://localhost:8080",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "llama.cpp API key",
    "credentialEnv": "LLAMACPP_API_KEY",
    "credentialOptional": true,
    "authTokenFallback": "llamacpp",
    "authTokenAlsoSetsApiKey": true
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": true
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "defaultVariantName": "ccllamacpp",
    "splashStyle": "llamacpp",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "llama.cpp",
      "palette": {
        "base": "#0d1208",
        "surface": "#141e0e",
        "panel": "#1a2812",
        "border": "#2e4a1e",
        "borderStrong": "#446d2e",
        "text": "#eef5e0",
        "textMuted": "#c8d8b0",
        "textDim": "#8aa868",
        "accent": "#84cc16",
        "accentSoft": "#a3e635",
        "accentDeep": "#65a30d",
        "blue": "#60a5fa",
        "green": "#84cc16",
        "red": "#fb2c36",
        "orange": "#ff8e42",
        "purple": "#9c8bff"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "llama.cpp",
    "section": "local",
    "modelDiscovery": {
      "enabled": true
    },
    "features": [
      "Local llama.cpp server",
      "OpenAI-compatible model list",
      "Optional API key for protected local endpoints"
    ],
    "setupLinks": {
      "docs": "https://github.com/ggml-org/llama.cpp/blob/master/tools/server/README.md",
      "apiKey": "https://github.com/ggml-org/llama.cpp/blob/master/tools/server/README.md",
      "subscribe": "https://github.com/ggml-org/llama.cpp"
    },
    "setupNote": "Run llama-server with an Anthropic-compatible route, then keep the default endpoint or edit the port."
  }
}
