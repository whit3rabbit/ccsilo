{
  "schemaVersion": 1,
  "key": "zai",
  "label": "Zai Cloud",
  "description": "GLM-5.2[1m] / 4.5-Air via Z.ai Coding Plan",
  "displayOrder": 30,
  "baseUrl": "https://api.z.ai/api/anthropic",
  "auth": {
    "mode": "apiKey",
    "apiKeyLabel": "Zai API key",
    "credentialEnv": "Z_AI_API_KEY"
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "glm-5.2[1m]",
    "sonnet": "glm-5.2[1m]",
    "haiku": "glm-4.5-air",
    "subagent": "",
    "requiresModelMapping": false
  },
  "env": {
    "API_TIMEOUT_MS": "3000000",
    "MCP_TOOL_TIMEOUT": "120000",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "1000000"
  },
  "variant": {
    "splashStyle": "zai",
    "noPromptPack": false,
    "theme": {
      "id": "dark",
      "name": "Zai Cloud",
      "palette": {
        "base": "#191b1e",
        "surface": "#222529",
        "panel": "#292d33",
        "border": "#3e4350",
        "borderStrong": "#545a6a",
        "text": "#eff0f3",
        "textMuted": "#cdd0d8",
        "textDim": "#9a9daa",
        "accent": "#ffd373",
        "accentSoft": "#ffe4a8",
        "accentDeep": "#b2892e",
        "blue": "#0080ff",
        "green": "#37d995",
        "red": "#fb2c36",
        "orange": "#ff8e42",
        "purple": "#9c8bff"
      }
    },
    "promptOverlays": {
      "webfetch": "When provider-specific docs, search, or page reading are relevant, prefer configured ZAI resources such as the ZAI docs and ZAI MCP tools available in this isolated setup.",
      "explore": "This Claude Code setup is configured for ZAI Cloud using GLM models through the ZAI Anthropic-compatible endpoint. Keep model and provider assumptions consistent with that endpoint.",
      "planEnhanced": "Plan with the active ZAI Cloud provider and GLM model mapping in mind. Do not assume first-party Claude model names or Anthropic-only behavior unless this setup explicitly configures them."
    }
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [
      "mcp__4_5v_mcp__analyze_image",
      "mcp__milk_tea_server__claim_milk_tea_coupon",
      "mcp__web_reader__webReader"
    ],
    "mcpServers": {
      "web-search-prime": {
        "type": "http",
        "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
        "headers": {
          "Authorization": "Bearer ${Z_AI_API_KEY}"
        }
      },
      "web-reader": {
        "type": "http",
        "url": "https://api.z.ai/api/mcp/web_reader/mcp",
        "headers": {
          "Authorization": "Bearer ${Z_AI_API_KEY}"
        }
      },
      "zread": {
        "type": "http",
        "url": "https://api.z.ai/api/mcp/zread/mcp",
        "headers": {
          "Authorization": "Bearer ${Z_AI_API_KEY}"
        }
      },
      "zai-mcp-server": {
        "type": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@z_ai/mcp-server"
        ],
        "env": {
          "Z_AI_API_KEY": "${Z_AI_API_KEY}",
          "Z_AI_MODE": "ZAI"
        }
      }
    }
  },
  "tui": {
    "headline": "Z.ai Coding Plan",
    "features": [
      "GLM-5.2[1m] Opus/Sonnet, GLM-4.5-Air Haiku",
      "Official Z.ai MCP servers registered",
      "Server-injected MCP tools denied in settings.json"
    ],
    "setupLinks": {
      "subscribe": "https://z.ai/subscribe",
      "apiKey": "https://z.ai/manage-apikey/apikey-list",
      "docs": "https://z.ai/docs"
    },
    "setupNote": "Subscribe to the Z.ai Coding Plan and provide Z_AI_API_KEY."
  }
}
