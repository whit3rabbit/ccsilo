{
  "schemaVersion": 1,
  "key": "poe",
  "label": "Poe",
  "description": "Claude via Poe Anthropic-compatible API",
  "displayOrder": 60,
  "baseUrl": "https://api.poe.com",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "Poe API key",
    "credentialEnv": "POE_API_KEY"
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": false
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "splashStyle": "poe",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "Poe",
      "palette": {
        "base": "#13151a",
        "surface": "#1a1d24",
        "panel": "#22252e",
        "border": "#3a3e4a",
        "borderStrong": "#4a4f5c",
        "text": "#e8eaed",
        "textMuted": "#b0b5bc",
        "textDim": "#7a8088",
        "accent": "#a855f7",
        "accentSoft": "#c084fc",
        "accentDeep": "#7c3aed",
        "blue": "#60a5fa",
        "green": "#37d995",
        "red": "#fb2c36",
        "orange": "#ff8e42",
        "purple": "#a855f7"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "Poe Anthropic API",
    "features": [
      "Official Anthropic-compatible endpoint",
      "Bearer-token compatibility",
      "Uses official Anthropic Claude bots"
    ],
    "setupLinks": {
      "subscribe": "https://poe.com/subscribe",
      "apiKey": "https://poe.com/api_key",
      "docs": "https://creator.poe.com/docs/external-applications/anthropic-compatible-api"
    },
    "setupNote": "Generate a Poe API key and expose it through POE_API_KEY."
  }
}
