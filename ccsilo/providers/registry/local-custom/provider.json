{
  "schemaVersion": 1,
  "key": "local-custom",
  "label": "Custom Local Endpoint",
  "description": "Custom local Anthropic or OpenAI-compatible endpoint",
  "displayOrder": 204,
  "baseUrl": "http://localhost:8000",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "Local API key",
    "credentialEnv": "LOCAL_LLM_API_KEY",
    "credentialOptional": true,
    "authTokenFallback": "local-llm",
    "authTokenAlsoSetsApiKey": true
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": true
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "defaultVariantName": "cclocal",
    "splashStyle": "local-custom",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "Custom Local Endpoint",
      "palette": {
        "base": "#13151a",
        "surface": "#1a1d24",
        "panel": "#22252e",
        "border": "#3a3e4a",
        "borderStrong": "#4a4f5c",
        "text": "#e8eaed",
        "textMuted": "#b0b5bc",
        "textDim": "#7a8088",
        "accent": "#9ca3af",
        "accentSoft": "#d1d5db",
        "accentDeep": "#6b7280",
        "blue": "#6ee7b7",
        "green": "#37d995",
        "red": "#fb2c36",
        "orange": "#ff8e42",
        "purple": "#9c8bff"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "Custom Local Endpoint",
    "section": "local",
    "modelDiscovery": {
      "enabled": true
    },
    "features": [
      "Editable local endpoint",
      "OpenAI-compatible model discovery",
      "Optional local API key"
    ],
    "setupLinks": {},
    "setupNote": "Use this for local gateways that expose /v1/models and Claude-compatible chat routes."
  }
}
