{
  "schemaVersion": 1,
  "key": "9router",
  "label": "9Router",
  "description": "Local 9Router gateway for provider fallback and format translation",
  "displayOrder": 105,
  "baseUrl": "http://localhost:20128/v1",
  "auth": {
    "mode": "apiKey",
    "apiKeyLabel": "9Router endpoint API key",
    "credentialEnv": "NINEROUTER_API_KEY"
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": true
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "splashStyle": "9router",
    "noPromptPack": true,
    "theme": {
      "id": "dark",
      "name": "9Router",
      "palette": {
        "base": "#13151a",
        "surface": "#1a1d24",
        "panel": "#22252e",
        "border": "#3a3e4a",
        "borderStrong": "#4a4f5c",
        "text": "#e8eaed",
        "textMuted": "#b0b5bc",
        "textDim": "#7a8088",
        "accent": "#f97316",
        "accentSoft": "#fb923c",
        "accentDeep": "#ea580c",
        "blue": "#60a5fa",
        "green": "#37d995",
        "red": "#fb2c36",
        "orange": "#f97316",
        "purple": "#9c8bff"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "9Router Local Gateway",
    "features": [
      "Routes through local 9Router at localhost:20128/v1",
      "Supports 9Router provider/model ids and combos",
      "Requires Opus, Sonnet, and Haiku model aliases"
    ],
    "setupLinks": {
      "dashboard": "http://localhost:20128/dashboard",
      "docs": "https://github.com/decolua/9router"
    },
    "setupNote": "Run 9Router locally, copy its endpoint API key, and provide NINEROUTER_API_KEY. Use --credential-env ROUTER_API_KEY if that is your local convention."
  }
}
