{
  "schemaVersion": 1,
  "key": "vercel",
  "label": "Vercel AI Gateway",
  "description": "Vercel AI Gateway",
  "displayOrder": 80,
  "baseUrl": "https://ai-gateway.vercel.sh",
  "auth": {
    "mode": "authToken",
    "apiKeyLabel": "Vercel AI Gateway API key",
    "credentialEnv": "VERCEL_AI_GATEWAY_KEY",
    "requiresEmptyApiKey": true
  },
  "models": {
    "default": "",
    "smallFast": "",
    "opus": "",
    "sonnet": "",
    "haiku": "",
    "subagent": "",
    "requiresModelMapping": true
  },
  "env": {
    "API_TIMEOUT_MS": "3000000"
  },
  "variant": {
    "defaultVariantName": "ccvercel",
    "splashStyle": "vercel",
    "noPromptPack": true,
    "theme": {
      "id": "vercel-variant",
      "name": "Vercel AI Gateway",
      "colors": {
        "bashBorder": "rgb(34,197,94)",
        "claude": "rgb(255,255,255)"
      }
    },
    "promptOverlays": {}
  },
  "claudeConfig": {
    "settingsPermissionsDeny": [],
    "mcpServers": {}
  },
  "tui": {
    "headline": "Vercel AI Gateway",
    "features": [
      "Centralized AI gateway",
      "Requires Opus, Sonnet, and Haiku model aliases",
      "Keeps ANTHROPIC_API_KEY empty for gateway auth"
    ],
    "setupLinks": {
      "subscribe": "https://vercel.com/ai",
      "apiKey": "https://vercel.com/account/tokens",
      "docs": "https://vercel.com/docs/ai-gateway"
    },
    "setupNote": "Use a Vercel token and set provider/model aliases for each tier."
  }
}
